datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  links        Link[]

  @@map("users")
}

model Link {
  id           String     @id @default(uuid())
  code         String     @unique // Base62 code or custom alias
  longUrl      String
  passwordHash String? // Optional password protection
  expiresAt    DateTime?
  isEnabled    Boolean    @default(true)
  userId       String? // Nullable for guest creators
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  analytics    Analytic[]

  @@index([code])
  @@map("links")
}

model Analytic {
  id        String   @id @default(uuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  clickedAt DateTime @default(now())
  ip        String
  country   String   @default("Unknown")
  city      String   @default("Unknown")
  browser   String   @default("Unknown")
  os        String   @default("Unknown")
  device    String   @default("Desktop")
  referrer  String   @default("Direct")

  @@index([linkId])
  @@map("analytics")
}
