# Database Connection (Postgres)
# Use localhost if running backend on host, or 'postgres' if running in Docker
DATABASE_URL="postgresql://postgres:postgrespassword123@localhost:5432/url_shortener?schema=public"

# Redis Cache URL
# Use localhost if running Redis on host, or 'redis' if running in Docker
REDIS_URL="redis://localhost:6379"

# Security Configuration
JWT_SECRET="glassmorphic-cyber-secret-key-987654321"

# Service Ports & URLs
PORT=5000
BASE_URL="http://localhost:5000"
FRONTEND_URL="http://localhost:3000"

# Environment
NODE_ENV="development"
